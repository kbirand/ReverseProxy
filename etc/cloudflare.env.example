# Cloudflare API token for DNS-01 ACME challenges (Let's Encrypt).
# The installer copies this to /etc/rproxy/cloudflare.env (mode 0640 root:caddy).
#
# Create a token at https://dash.cloudflare.com/profile/api-tokens with:
#   Permissions:  Zone > DNS  > Edit
#                 Zone > Zone > Read
#   Zone Resources: Include > All zones from an account
#
# Paste it below, then: sudo systemctl restart caddy
CF_API_TOKEN=
